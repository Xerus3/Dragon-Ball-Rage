-- ============================================
-- DBR WEBHOOK MODULE
-- Uses webhook proxy to bypass client restrictions
-- ============================================

local WebhookModule = {}

WebhookModule.Config = {
    WebhookUrl = "",
    TrackStats = {
        Agility = false,
        Attack = false,
        Defense = false,
        Ki = false,
    },
    TargetValues = {
        Agility = 0,
        Attack = 0,
        Defense = 0,
        Ki = 0,
    },
    Enabled = false
}

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local HttpService = game:GetService("HttpService")

function WebhookModule.GetStatValue(statName)
    local stats = LocalPlayer:WaitForChild("Stats", 5)
    if not stats then return nil end
    local stat = stats:FindFirstChild(statName)
    return stat and stat.Value or nil
end

-- Try multiple methods to send webhook
function WebhookModule.SendWebhook(title, description, color)
    if not WebhookModule.Config.WebhookUrl or WebhookModule.Config.WebhookUrl == "" then
        return false, "No webhook URL set"
    end
    
    local data = {
        embeds = {{
            title = title,
            description = description,
            color = color or 65280,
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
            footer = {
                text = "DBR Stat Tracker | " .. LocalPlayer.Name
            }
        }}
    }
    
    local body = HttpService:JSONEncode(data)
    
    -- Method 1: Try executor's request/syn.request
    local httpRequest = request or syn.request or http_request or fluxus_request
    
    if httpRequest then
        local success, response = pcall(function()
            return httpRequest({
                Url = WebhookModule.Config.WebhookUrl,
                Method = "POST",
                Headers = {
                    ["Content-Type"] = "application/json"
                },
                Body = body
            })
        end)
        
        if success and response then
            local statusCode = response.StatusCode or response.status
            if statusCode and statusCode >= 200 and statusCode < 300 then
                return true, "Webhook sent via executor"
            end
        end
    end
    
    -- Method 2: Try webhook proxy services
    local proxyUrls = {
        "https://hooks.hyra.io/api/webhooks/",      -- Hyra proxy
        "https://webhook.lewisakura.moe/api/webhooks/", -- Lewisakura proxy
    }
    
    -- Extract webhook ID and token from URL
    local webhookId, webhookToken = WebhookModule.Config.WebhookUrl:match("discord.com/api/webhooks/(%d+)/(.+)")
    
    if webhookId and webhookToken then
        for _, proxyBase in ipairs(proxyUrls) do
            local proxyUrl = proxyBase .. webhookId .. "/" .. webhookToken
            
            local success, response = pcall(function()
                return HttpService:PostAsync(
                    proxyUrl,
                    body,
                    Enum.HttpContentType.ApplicationJson
                )
            end)
            
            if success then
                return true, "Webhook sent via proxy"
            end
        end
    end
    
    -- Method 3: Try direct with HttpService (will likely fail but worth a shot)
    local success, err = pcall(function()
        return HttpService:PostAsync(
            WebhookModule.Config.WebhookUrl,
            body,
            Enum.HttpContentType.ApplicationJson
        )
    end)
    
    if success then
        return true, "Webhook sent directly"
    end
    
    return false, "All methods failed. Last error: " .. tostring(err)
end

function WebhookModule.StartTracking()
    if WebhookModule.Config.Enabled then
        return false, "Already tracking"
    end
    
    local anySelected = false
    for _, enabled in pairs(WebhookModule.Config.TrackStats) do
        if enabled then
            anySelected = true
            break
        end
    end
    
    if not anySelected then
        return false, "No stats selected to track"
    end
    
    WebhookModule.Config.Enabled = true
    
    task.spawn(function()
        local notifiedStats = {}
        
        while WebhookModule.Config.Enabled do
            local currentStats = {}
            local allStatsReady = true
            local readyStats = {}
            local pendingStats = {}
            
            for statName, enabled in pairs(WebhookModule.Config.TrackStats) do
                if enabled then
                    local currentValue = WebhookModule.GetStatValue(statName)
                    local targetValue = WebhookModule.Config.TargetValues[statName] or 0
                    
                    if currentValue then
                        currentStats[statName] = currentValue
                        
                        if currentValue >= targetValue then
                            if not notifiedStats[statName] then
                                table.insert(readyStats, statName)
                                notifiedStats[statName] = true
                            end
                        else
                            allStatsReady = false
                            notifiedStats[statName] = false
                            table.insert(pendingStats, statName .. ": " .. tostring(currentValue) .. "/" .. tostring(targetValue))
                        end
                    end
                end
            end
            
            for _, statName in ipairs(readyStats) do
                local success, msg = WebhookModule.SendWebhook(
                    "🎯 " .. statName .. " Target Reached!",
                    string.format(
                        "**%s** has reached the target!\n\nCurrent: **%s**\nTarget: **%s**\n\nPending stats:\n%s",
                        statName,
                        tostring(currentStats[statName]),
                        tostring(WebhookModule.Config.TargetValues[statName]),
                        #pendingStats > 0 and table.concat(pendingStats, "\n") or "All stats ready!"
                    ),
                    3066993
                )
                
                if success then
                    print("[Webhook] Notification sent for " .. statName)
                else
                    print("[Webhook] Failed: " .. msg)
                end
                
                task.wait(1)
            end
            
            if allStatsReady and #readyStats > 1 then
                local allStatsList = {}
                for statName, enabled in pairs(WebhookModule.Config.TrackStats) do
                    if enabled then
                        table.insert(allStatsList, statName .. ": " .. tostring(currentStats[statName]))
                    end
                end
                
                WebhookModule.SendWebhook(
                    "✅ ALL STATS READY FOR REBIRTH!",
                    "All tracked stats have reached their targets!\n\n" .. table.concat(allStatsList, "\n"),
                    3066993
                )
                
                WebhookModule.Config.Enabled = false
                break
            end
            
            task.wait(5)
        end
    end)
    
    return true, "Tracking started"
end

function WebhookModule.StopTracking()
    WebhookModule.Config.Enabled = false
    return true, "Tracking stopped"
end

function WebhookModule.UpdateConfig(webhookUrl, trackStats, targetValues)
    WebhookModule.Config.WebhookUrl = webhookUrl
    WebhookModule.Config.TrackStats = trackStats
    WebhookModule.Config.TargetValues = targetValues
    return true, "Config updated"
end

return WebhookModule
